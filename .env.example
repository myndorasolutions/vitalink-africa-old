# App
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGODB_DB=vitalink_dev

# Redis
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_PROJECT_ID=vitalink-africa-dev
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# GCP
GCP_PROJECT_ID=vitalink-africa-dev
GCP_REGION=africa-south1
GCS_PATIENT_FILES_BUCKET=vitalink-patient-files-dev
GCS_PROVIDER_DOCS_BUCKET=vitalink-provider-docs-dev
GCS_VITALS_EXPORTS_BUCKET=vitalink-vitals-exports-dev
MOCK_GCS=true

# Africa's Talking
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key
AT_SENDER_ID=VitaLink
AT_USSD_CODE=*384*VITALINK#
MOCK_AT=true

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_key
PAYSTACK_PUBLIC_KEY=pk_test_your_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
MOCK_PAYSTACK=true

# Commission rates
VITALINK_CHW_COMMISSION=0.15
VITALINK_CLINICIAN_COMMISSION=0.20
VITALINK_PHARMACY_COMMISSION=0.05
VITALINK_LAB_COMMISSION=0.08

# Feature flags (override via DB)
FEATURE_AI_SUMMARIES=false
FEATURE_PAYSTACK_LIVE=false
FEATURE_USSD=true
FEATURE_MARKETPLACE=true
FEATURE_PRESCRIPTION_WORKFLOW=true

# Escrow
ESCROW_AUTO_RELEASE_HOURS=48

# Web
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
